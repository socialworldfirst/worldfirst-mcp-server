# WorldFirst MCP Server Configuration
# Copy to .env and fill in your credentials

# Your WorldFirst Client ID (from Developer Center)
WORLDFIRST_CLIENT_ID=your_client_id_here

# RSA private key (PEM format) — paste the full key or use newline escapes
# Generate with: openssl genrsa -out private_key.pem 2048
# Then share the public key with WorldFirst
WORLDFIRST_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----"

# Environment: "sandbox" (default) or "production"
WORLDFIRST_ENVIRONMENT=sandbox

# Region: "sg" (Singapore, default), "eu" (Europe), "us" (United States)
WORLDFIRST_REGION=sg
